@using suneer_web.Models
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Welcome bar -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0">Welcome back</h4>
        <p class="text-muted small mb-0">@User.Identity?.Name</p>
    </div>
    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2">
        <i class="bi bi-circle-fill me-1" style="font-size:.5rem"></i>Online
    </span>
</div>

<!-- Stats cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <a asp-area="Admin" asp-controller="Projects" asp-action="Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 bg-primary bg-opacity-10 p-3">
                        <i class="bi bi-folder2-open fs-4 text-primary"></i>
                    </div>
                    <div>
                        <div class="fs-4 fw-bold">@ViewBag.ProjectCount</div>
                        <div class="text-muted small">Projects</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-area="Admin" asp-controller="Skills" asp-action="Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 bg-success bg-opacity-10 p-3">
                        <i class="bi bi-stars fs-4 text-success"></i>
                    </div>
                    <div>
                        <div class="fs-4 fw-bold">@ViewBag.SkillCount</div>
                        <div class="text-muted small">Skills</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-area="Admin" asp-controller="Experience" asp-action="Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 bg-warning bg-opacity-10 p-3">
                        <i class="bi bi-briefcase fs-4 text-warning"></i>
                    </div>
                    <div>
                        <div class="fs-4 fw-bold">@ViewBag.ExperienceCount</div>
                        <div class="text-muted small">Experience</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-area="Admin" asp-controller="Messages" asp-action="Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 bg-info bg-opacity-10 p-3">
                        <i class="bi bi-envelope fs-4 text-info"></i>
                    </div>
                    <div>
                        <div class="fs-4 fw-bold">@ViewBag.MessageCount</div>
                        <div class="text-muted small">Messages</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>

<!-- Quick Actions + Recent Messages -->
<div class="row g-4">
    <!-- Quick Actions -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 pt-3 pb-0">
                <h6 class="fw-bold mb-0">Quick Actions</h6>
            </div>
            <div class="card-body d-flex flex-column gap-2 pt-3">
                <a asp-area="Admin" asp-controller="Profile" asp-action="Edit"
                   class="btn btn-outline-secondary btn-sm text-start">
                    <i class="bi bi-person-vcard me-2"></i>Edit Profile
                </a>
                <a asp-area="Admin" asp-controller="Projects" asp-action="Create"
                   class="btn btn-outline-secondary btn-sm text-start">
                    <i class="bi bi-plus-circle me-2"></i>Add Project
                </a>
                <a asp-area="Admin" asp-controller="Skills" asp-action="Create"
                   class="btn btn-outline-secondary btn-sm text-start">
                    <i class="bi bi-plus-circle me-2"></i>Add Skill
                </a>
                <a asp-area="Admin" asp-controller="Experience" asp-action="Create"
                   class="btn btn-outline-secondary btn-sm text-start">
                    <i class="bi bi-plus-circle me-2"></i>Add Experience
                </a>
                <a asp-area="Admin" asp-controller="Education" asp-action="Create"
                   class="btn btn-outline-secondary btn-sm text-start">
                    <i class="bi bi-plus-circle me-2"></i>Add Education
                </a>
                <hr class="my-1" />
                <a asp-controller="Home" asp-action="Index" asp-area="" target="_blank"
                   class="btn btn-outline-primary btn-sm text-start">
                    <i class="bi bi-box-arrow-up-right me-2"></i>View Public Site
                </a>
            </div>
        </div>
    </div>

    <!-- Recent Messages -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 pt-3 pb-0 d-flex align-items-center justify-content-between">
                <h6 class="fw-bold mb-0">Recent Messages</h6>
                <a asp-area="Admin" asp-controller="Messages" asp-action="Index"
                   class="small text-decoration-none">View all</a>
            </div>
            <div class="card-body pt-3">
                @{
                    var msgs = ViewBag.RecentMessages as List<ContactMessage>;
                }
                @if (msgs == null || !msgs.Any())
                {
                    <p class="text-muted small mb-0 text-center py-3">No messages yet.</p>
                }
                else
                {
                    <ul class="list-unstyled mb-0">
                        @{ int msgIdx = 0; }
                        @foreach (var msg in msgs)
                        {
                            msgIdx++;
                            <li class="d-flex gap-3 pb-3 @(msgIdx < msgs.Count ? "border-bottom mb-3" : "")">
                                <div class="rounded-circle bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0"
                                     style="width:36px;height:36px">
                                    <i class="bi bi-person text-secondary"></i>
                                </div>
                                <div class="overflow-hidden">
                                    <div class="d-flex align-items-baseline gap-2">
                                        <span class="fw-semibold small">@msg.Name</span>
                                        <span class="text-muted" style="font-size:.75rem">@msg.CreatedAt.ToString("MMM dd")</span>
                                    </div>
                                    <p class="text-muted small mb-0 text-truncate">@msg.Message</p>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
