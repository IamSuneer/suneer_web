@model ProjectsViewModel
@{
    ViewData["Title"] = "Projects";
}

<!-- Page header -->
<section class="section-pad-sm" style="background: var(--bs-secondary-bg)">
    <div class="container">
        <p class="section-label">What I've built</p>
        <h1 class="section-title">My <span>Projects</span></h1>
        <div class="section-divider left"></div>
        <p class="text-secondary">@Model.Projects.Count project@(Model.Projects.Count == 1 ? "" : "s") — click a tag to filter</p>
    </div>
</section>

<section class="section-pad">
    <div class="container">

        <!-- Filter pills -->
        @if (Model.TechTags.Any())
        {
            <div class="d-flex flex-wrap gap-2 mb-5">
                <button class="btn btn-outline-secondary filter-pill active" data-filter="all">
                    All <span class="badge bg-primary ms-1">@Model.Projects.Count</span>
                </button>
                @foreach (var tag in Model.TechTags)
                {
                    <button class="btn btn-outline-secondary filter-pill" data-filter="@tag">
                        @tag
                    </button>
                }
            </div>
        }

        <!-- Project grid -->
        @if (Model.Projects.Any())
        {
            <div class="row g-4" id="projectsGrid">
                @foreach (var project in Model.Projects)
                {
                    var tags = string.Join(",", project.TechStack
                        .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries));

                    <div class="col-md-6 col-xl-4 animate-up project-card-wrapper" data-tags="@tags.ToLower()">
                        <div class="project-card">
                            <div class="project-img-placeholder">
                                @if (!string.IsNullOrWhiteSpace(project.ImageUrl))
                                {
                                    <img src="@project.ImageUrl" alt="@project.Title"
                                         style="width:100%;height:100%;object-fit:cover" />
                                }
                                else
                                {
                                    <i class="bi bi-code-square"></i>
                                }
                            </div>

                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-2">@project.Title</h5>
                                <p class="text-secondary small lh-lg mb-3">
                                    @(project.Description.Length > 140
                                        ? project.Description[..140] + "…"
                                        : project.Description)
                                </p>

                                <!-- Tech badges -->
                                <div class="mb-3">
                                    @foreach (var tag in project.TechStack
                                        .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <span class="tech-badge">@tag</span>
                                    }
                                </div>

                                <!-- Links -->
                                <div class="d-flex gap-2 flex-wrap mt-auto pt-2 border-top">
                                    @if (!string.IsNullOrWhiteSpace(project.GitHubUrl))
                                    {
                                        <a href="@project.GitHubUrl" target="_blank" rel="noopener"
                                           class="project-link text-secondary d-inline-flex align-items-center gap-1">
                                            <i class="bi bi-github"></i> Source Code
                                        </a>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(project.LiveUrl))
                                    {
                                        <a href="@project.LiveUrl" target="_blank" rel="noopener"
                                           class="project-link text-primary d-inline-flex align-items-center gap-1 ms-auto">
                                            <i class="bi bi-box-arrow-up-right"></i> Live Demo
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5 text-secondary">
                <i class="bi bi-folder-x display-3 d-block mb-3"></i>
                No projects found.
            </div>
        }

    </div>
</section>
