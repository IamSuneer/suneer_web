@model List<suneer_web.Models.Education>
@{
    ViewData["Title"] = "Education";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0">Education</h4>
        <p class="text-muted small mb-0">@Model.Count entry(s) total</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Add Education
    </a>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-mortarboard fs-1 d-block mb-2 opacity-25"></i>
            No education entries yet. <a asp-action="Create">Add your first entry.</a>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Degree</th>
                        <th>School</th>
                        <th>Period</th>
                        <th style="width:100px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var edu in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@edu.Degree</td>
                            <td>@edu.School</td>
                            <td class="text-muted small">
                                @edu.StartDate.ToString("MMM yyyy") –
                                @(edu.EndDate.HasValue ? edu.EndDate.Value.ToString("MMM yyyy") : "Present")
                            </td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="Edit" asp-route-id="@edu.Id"
                                       class="btn btn-sm btn-outline-secondary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" asp-action="Delete" asp-route-id="@edu.Id"
                                          onsubmit="return confirm('Delete this education entry?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
