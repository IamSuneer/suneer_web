@{
    var ctrl   = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    string Nav(string a) => action == a && ctrl == "Home" ? "active fw-semibold" : "";
}
<!DOCTYPE html>
<html lang="en" id="htmlRoot" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Suneer Ranjitkar</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <nav class="navbar navbar-expand-lg sticky-top site-navbar shadow-sm">
        <div class="container">
            <a class="navbar-brand brand-logo" asp-controller="Home" asp-action="Index">
                <span class="brand-bracket">&lt;</span>SR<span class="brand-bracket">/&gt;</span>
            </a>

            <div class="d-flex align-items-center gap-2 order-lg-last">
                <!-- Dark mode toggle -->
                <button id="themeToggle" class="btn btn-sm btn-outline-secondary rounded-circle p-2"
                        title="Toggle dark mode" aria-label="Toggle dark/light mode">
                    <i class="bi bi-moon-fill" id="themeIcon" style="font-size:.85rem"></i>
                </button>
                <!-- Mobile hamburger -->
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                        data-bs-target="#mainNav" aria-controls="mainNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
            </div>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-lg-1">
                    <li class="nav-item">
                        <a class="nav-link px-3 @Nav("Index")" asp-controller="Home" asp-action="Index">
                            Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-3 @Nav("About")" asp-controller="Home" asp-action="About">
                            About
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-3 @Nav("Resume")" asp-controller="Home" asp-action="Resume">
                            Resume
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-3 @Nav("Projects")" asp-controller="Home" asp-action="Projects">
                            Projects
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-3 @Nav("Contact")" asp-controller="Home" asp-action="Contact">
                            Contact
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer py-5 mt-5">
        <div class="container text-center">
            <div class="brand-logo fs-4 mb-2">
                <span class="brand-bracket">&lt;</span>SR<span class="brand-bracket">/&gt;</span>
            </div>
            <p class="text-secondary small mb-3">
                Full-Stack Developer &amp; Software Engineer
            </p>
            <div class="d-flex justify-content-center gap-3 mb-4">
                <a href="#" class="footer-link" title="GitHub"><i class="bi bi-github fs-5"></i></a>
                <a href="#" class="footer-link" title="LinkedIn"><i class="bi bi-linkedin fs-5"></i></a>
                <a href="#" class="footer-link" title="Email"><i class="bi bi-envelope fs-5"></i></a>
            </div>
            <p class="text-secondary" style="font-size:.8rem">
                &copy; @DateTime.Now.Year Suneer Ranjitkar &mdash; Built with ASP.NET Core 8 &amp; Bootstrap 5
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmJ5MbHZ/QHaXEpGp8apKAkGM0P"
            crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
