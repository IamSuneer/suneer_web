@model suneer_web.Models.Skill
@{
    ViewData["Title"] = "Add Skill";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0">Add Skill</h4>
        <p class="text-muted small mb-0">Add a new skill to your profile</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<div class="card border-0 shadow-sm" style="max-width:520px">
    <div class="card-body p-4">
        <form method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold">Skill Name</label>
                <input asp-for="Name" class="form-control" placeholder="e.g. C#, React, Docker" autofocus />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Level" class="form-label fw-semibold">
                    Proficiency Level — <span id="levelDisplay">@Model.Level</span>%
                </label>
                <input asp-for="Level" type="range" class="form-range" min="0" max="100" step="5"
                       oninput="document.getElementById('levelDisplay').textContent=this.value" />
                <div class="d-flex justify-content-between text-muted" style="font-size:.75rem">
                    <span>Beginner</span><span>Intermediate</span><span>Expert</span>
                </div>
                <span asp-validation-for="Level" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-plus-lg me-1"></i>Add Skill
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
