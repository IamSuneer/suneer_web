@model List<suneer_web.Models.ContactMessage>
@{
    ViewData["Title"] = "Messages";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0">Messages</h4>
        <p class="text-muted small mb-0">@Model.Count message(s) received</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-envelope fs-1 d-block mb-2 opacity-25"></i>
            No messages yet. Messages from your contact form will appear here.
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>From</th>
                        <th>Email</th>
                        <th>Message</th>
                        <th style="width:110px">Date</th>
                        <th style="width:90px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var msg in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@msg.Name</td>
                            <td>
                                <a href="mailto:@msg.Email" class="text-decoration-none text-secondary small">
                                    @msg.Email
                                </a>
                            </td>
                            <td>
                                <span class="text-truncate d-block text-secondary small" style="max-width:280px"
                                      title="@msg.Message">
                                    @msg.Message
                                </span>
                            </td>
                            <td class="text-muted small">@msg.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <button type="button" class="btn btn-sm btn-outline-secondary"
                                            title="View full message"
                                            data-bs-toggle="modal" data-bs-target="#msgModal"
                                            data-name="@msg.Name"
                                            data-email="@msg.Email"
                                            data-date="@msg.CreatedAt.ToString("MMMM dd, yyyy 'at' HH:mm")"
                                            data-message="@msg.Message">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <form method="post" asp-action="Delete" asp-route-id="@msg.Id"
                                          onsubmit="return confirm('Delete this message?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- View Message Modal -->
<div class="modal fade" id="msgModal" tabindex="-1" aria-labelledby="msgModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <div>
                    <h5 class="modal-title fw-bold mb-0" id="msgModalLabel">Message from <span id="modalName"></span></h5>
                    <p class="text-muted small mb-0" id="modalMeta"></p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <hr class="mt-2" />
                <p id="modalMessage" class="mb-0" style="white-space:pre-wrap"></p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <a id="modalReply" href="#" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-reply me-1"></i>Reply via Email
                </a>
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('msgModal').addEventListener('show.bs.modal', function (e) {
            var btn = e.relatedTarget;
            document.getElementById('modalName').textContent    = btn.dataset.name;
            document.getElementById('modalMeta').textContent    = btn.dataset.email + ' · ' + btn.dataset.date;
            document.getElementById('modalMessage').textContent = btn.dataset.message;
            document.getElementById('modalReply').href          = 'mailto:' + btn.dataset.email;
        });
    </script>
}
