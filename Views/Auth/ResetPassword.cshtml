@model suneer_web.Models.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password — Suneer Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #1e2a3a 0%, #0d1b2a 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .auth-card { width: 100%; max-width: 420px; border-radius: 1rem; }

        /* Strength bar */
        #strengthBar {
            height: 4px;
            border-radius: 2px;
            transition: width .3s, background .3s;
        }
    </style>
</head>
<body>

<div class="auth-card card border-0 shadow-lg p-4">
    <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3
                    bg-success bg-opacity-10" style="width:64px;height:64px">
            <i class="bi bi-lock-fill fs-3 text-success"></i>
        </div>
        <h4 class="fw-bold mb-0">New Password</h4>
        <p class="text-muted small">Choose a strong password for your admin account.</p>
    </div>

    <form asp-controller="PasswordReset" asp-action="ResetPassword" asp-area="" method="post">
        @Html.AntiForgeryToken()

        <!-- Carry email + code silently — re-validated server-side -->
        <input type="hidden" asp-for="Email" />
        <input type="hidden" asp-for="Code"  />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

        <div class="mb-3">
            <label asp-for="NewPassword" class="form-label fw-semibold small"></label>
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0">
                    <i class="bi bi-lock text-muted"></i>
                </span>
                <input asp-for="NewPassword"
                       id="newPwd"
                       class="form-control border-start-0 ps-0"
                       placeholder="Min. 8 characters"
                       autocomplete="new-password" />
                <button type="button" class="btn btn-outline-secondary border-start-0"
                        onclick="togglePwd('newPwd', this)"
                        tabindex="-1">
                    <i class="bi bi-eye"></i>
                </button>
            </div>
            <!-- Strength bar -->
            <div class="mt-1 bg-secondary bg-opacity-25 rounded" style="height:4px">
                <div id="strengthBar" style="width:0;background:#dc3545"></div>
            </div>
            <span asp-validation-for="NewPassword" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="ConfirmPassword" class="form-label fw-semibold small"></label>
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0">
                    <i class="bi bi-lock-fill text-muted"></i>
                </span>
                <input asp-for="ConfirmPassword"
                       id="confirmPwd"
                       class="form-control border-start-0 ps-0"
                       placeholder="Repeat password"
                       autocomplete="new-password" />
                <button type="button" class="btn btn-outline-secondary border-start-0"
                        onclick="togglePwd('confirmPwd', this)"
                        tabindex="-1">
                    <i class="bi bi-eye"></i>
                </button>
            </div>
            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-success w-100 py-2 fw-semibold">
            <i class="bi bi-check-circle me-2"></i>Reset Password
        </button>
    </form>

    <p class="text-center text-muted small mt-4 mb-0">
        <a asp-controller="Auth" asp-action="Page" asp-area=""
           class="text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i>Back to Login
        </a>
    </p>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmJ5MbHZ/QHaXEpGp8apKAkGM0P"
        crossorigin="anonymous"></script>
<script>
    function togglePwd(id, btn) {
        var input = document.getElementById(id);
        var icon  = btn.querySelector('i');
        if (input.type === 'password') {
            input.type = 'text';
            icon.className = 'bi bi-eye-slash';
        } else {
            input.type = 'password';
            icon.className = 'bi bi-eye';
        }
    }

    document.getElementById('newPwd').addEventListener('input', function () {
        var v = this.value;
        var score = 0;
        if (v.length >= 8)  score++;
        if (/[A-Z]/.test(v)) score++;
        if (/[0-9]/.test(v)) score++;
        if (/[^A-Za-z0-9]/.test(v)) score++;

        var bar    = document.getElementById('strengthBar');
        var widths = ['0%', '25%', '50%', '75%', '100%'];
        var colors = ['#dc3545', '#dc3545', '#f59e0b', '#3b82f6', '#22c55e'];
        bar.style.width      = widths[score];
        bar.style.background = colors[score];
    });
</script>
<partial name="_ValidationScriptsPartial" />
</body>
</html>
