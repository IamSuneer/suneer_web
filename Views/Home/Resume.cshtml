@model ResumeViewModel
@{
    ViewData["Title"] = "Resume";
}

<!-- Page header -->
<section class="section-pad-sm" style="background: var(--bs-secondary-bg)">
    <div class="container d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
            <p class="section-label mb-1">Career overview</p>
            <h1 class="section-title mb-0">My <span>Resume</span></h1>
        </div>
        @{
            var pdfPath = System.IO.Path.Combine(
                System.IO.Directory.GetCurrentDirectory(), "wwwroot", "files", "cv-suneer.pdf");
        }
        @if (System.IO.File.Exists(pdfPath))
        {
            <a href="/files/cv-suneer.pdf" download class="btn btn-primary">
                <i class="bi bi-download me-2"></i>Download PDF
            </a>
        }
    </div>
</section>

<section class="section-pad">
    <div class="container">
        <div class="row g-5">

            <!-- Left column: Skills -->
            <div class="col-lg-4">
                <div class="animate-up">
                    <p class="section-label">Proficiency</p>
                    <h3 class="fw-bold mb-1">Technical <span class="text-primary">Skills</span></h3>
                    <div class="section-divider left mb-4"></div>

                    @foreach (var skill in Model.Skills)
                    {
                        <div class="skill-item">
                            <div class="skill-header">
                                <span class="skill-name">@skill.Name</span>
                                <span class="skill-pct">@skill.Level%</span>
                            </div>
                            <div class="skill-track">
                                <div class="skill-fill" data-width="@skill.Level"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Right column: Experience + Education -->
            <div class="col-lg-8">

                <!-- Experience -->
                @if (Model.Experiences.Any())
                {
                    <div class="mb-5 animate-up">
                        <p class="section-label">Career</p>
                        <h3 class="fw-bold mb-1">Work <span class="text-primary">Experience</span></h3>
                        <div class="section-divider left mb-4"></div>

                        <div class="timeline">
                            @foreach (var exp in Model.Experiences)
                            {
                                var endLabel = exp.EndDate.HasValue
                                    ? exp.EndDate.Value.ToString("MMM yyyy")
                                    : "Present";
                                <div class="timeline-item animate-up">
                                    <div class="timeline-dot"></div>
                                    <div class="timeline-card">
                                        <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-1">
                                            <div>
                                                <div class="timeline-role">@exp.Role</div>
                                                <div class="timeline-company">
                                                    <i class="bi bi-building me-1"></i>@exp.Company
                                                </div>
                                            </div>
                                            <span class="badge bg-primary-subtle text-primary-emphasis border border-primary-subtle"
                                                  style="font-size:.73rem; white-space:nowrap">
                                                @exp.StartDate.ToString("MMM yyyy") — @endLabel
                                            </span>
                                        </div>
                                        <p class="text-secondary small mb-0 lh-lg">@exp.Description</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Education -->
                @if (Model.Educations.Any())
                {
                    <div class="animate-up">
                        <p class="section-label">Academic</p>
                        <h3 class="fw-bold mb-1">Education <span class="text-primary">History</span></h3>
                        <div class="section-divider left mb-4"></div>

                        <div class="timeline">
                            @foreach (var edu in Model.Educations)
                            {
                                var endLabel = edu.EndDate.HasValue
                                    ? edu.EndDate.Value.ToString("MMM yyyy")
                                    : "Present";
                                <div class="timeline-item animate-up">
                                    <div class="timeline-dot" style="background:#8b5cf6"></div>
                                    <div class="timeline-card">
                                        <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-1">
                                            <div>
                                                <div class="timeline-role">@edu.Degree</div>
                                                <div class="timeline-company">
                                                    <i class="bi bi-mortarboard me-1"></i>@edu.School
                                                </div>
                                            </div>
                                            <span class="badge bg-purple-subtle text-purple border"
                                                  style="font-size:.73rem; white-space:nowrap;
                                                         background:rgba(139,92,246,.1)!important;
                                                         color:#7c3aed!important;
                                                         border-color:rgba(139,92,246,.25)!important">
                                                @edu.StartDate.ToString("MMM yyyy") — @endLabel
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
</section>
