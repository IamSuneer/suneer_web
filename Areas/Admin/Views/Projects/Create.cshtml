@model suneer_web.Models.Project
@{
    ViewData["Title"] = "Add Project";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0">Add Project</h4>
        <p class="text-muted small mb-0">Add a new project to your portfolio</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<div class="card border-0 shadow-sm" style="max-width:720px">
    <div class="card-body p-4">
        <form method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2" role="alert"></div>

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Title" class="form-label fw-semibold">Project Title</label>
                    <input asp-for="Title" class="form-control" placeholder="e.g. E-Commerce Platform" autofocus />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label fw-semibold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="4"
                              placeholder="Describe the project, what it does, and your role..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="TechStack" class="form-label fw-semibold">Tech Stack</label>
                    <input asp-for="TechStack" class="form-control" placeholder="e.g. C#, .NET 8, React, SQLite" />
                    <div class="form-text">Comma-separated values</div>
                    <span asp-validation-for="TechStack" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="GitHubUrl" class="form-label fw-semibold">
                        GitHub URL <span class="text-muted fw-normal">(optional)</span>
                    </label>
                    <input asp-for="GitHubUrl" class="form-control" placeholder="https://github.com/user/repo" />
                    <span asp-validation-for="GitHubUrl" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="LiveUrl" class="form-label fw-semibold">
                        Live URL <span class="text-muted fw-normal">(optional)</span>
                    </label>
                    <input asp-for="LiveUrl" class="form-control" placeholder="https://myproject.com" />
                    <span asp-validation-for="LiveUrl" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="ImageUrl" class="form-label fw-semibold">
                        Image URL <span class="text-muted fw-normal">(optional)</span>
                    </label>
                    <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/screenshot.png" />
                    <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                </div>
            </div>

            <hr class="my-4" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-plus-lg me-1"></i>Add Project
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
