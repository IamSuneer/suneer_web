@model suneer_web.Models.Profile
@{
    ViewData["Title"] = "Profile";
    bool isNew = Model.Id == 0;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0">@(isNew ? "Create Profile" : "Edit Profile")</h4>
        <p class="text-muted small mb-0">Your public CV profile information</p>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <form method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2" role="alert"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label fw-semibold">Full Name</label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. John Doe" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Title" class="form-label fw-semibold">Professional Title</label>
                    <input asp-for="Title" class="form-control" placeholder="e.g. Full Stack Developer" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Bio" class="form-label fw-semibold">Bio</label>
                    <textarea asp-for="Bio" class="form-control" rows="5"
                              placeholder="Write a short professional bio..."></textarea>
                    <span asp-validation-for="Bio" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="ImageUrl" class="form-label fw-semibold">
                        Profile Image URL <span class="text-muted fw-normal">(optional)</span>
                    </label>
                    <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/photo.jpg" />
                    <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                    {
                        <div class="mt-2">
                            <img src="@Model.ImageUrl" alt="Profile preview"
                                 class="rounded-circle" style="width:64px;height:64px;object-fit:cover;"
                                 onerror="this.style.display='none'" />
                        </div>
                    }
                </div>
            </div>

            <hr class="my-4" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-check-lg me-1"></i>@(isNew ? "Create Profile" : "Save Changes")
                </button>
            </div>
        </form>
    </div>
</div>
