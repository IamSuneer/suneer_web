@model HomeViewModel
@{
    ViewData["Title"] = "Home";
    var profile  = Model.Profile;
    var name     = profile?.Name  ?? "Suneer Ranjitkar";
    var title    = profile?.Title ?? "Full-Stack Developer & Software Engineer";
    var bio      = profile?.Bio   ?? "";
}

<!-- ===== HERO ===== -->
<section class="hero-section">
    <div class="container position-relative">
        <div class="row align-items-center justify-content-between g-5">

            <!-- Left: text -->
            <div class="col-lg-7 text-center text-lg-start">
                <p class="section-label mb-3">Welcome to my portfolio</p>
                <h1 class="hero-name mb-2">@name</h1>
                <p class="hero-title">@title</p>

                @if (!string.IsNullOrWhiteSpace(bio))
                {
                    <p class="hero-bio">
                        @(bio.Length > 220 ? bio[..220] + "…" : bio)
                    </p>
                }

                <div class="hero-badges">
                    <span class="hero-badge"><i class="bi bi-dot text-success"></i> Available for work</span>
                    <span class="hero-badge"><i class="bi bi-geo-alt me-1"></i>Nepal</span>
                    <span class="hero-badge"><i class="bi bi-briefcase me-1"></i>.NET &amp; Web</span>
                </div>

                <div class="d-flex flex-wrap justify-content-center justify-content-lg-start gap-3">
                    <a asp-action="Projects" class="btn btn-primary btn-lg px-5">
                        <i class="bi bi-folder2-open me-2"></i>View Projects
                    </a>
                    <a asp-action="Contact" class="btn btn-outline-secondary btn-lg px-5">
                        <i class="bi bi-envelope me-2"></i>Contact Me
                    </a>
                    <a asp-action="Resume" class="btn btn-outline-secondary btn-lg px-4">
                        <i class="bi bi-file-earmark-person me-2"></i>Resume
                    </a>
                </div>
            </div>

            <!-- Right: avatar -->
            <div class="col-lg-4 text-center">
                @if (!string.IsNullOrWhiteSpace(profile?.ImageUrl))
                {
                    <img src="@profile.ImageUrl" alt="@name" class="hero-avatar mx-auto d-block" />
                }
                else
                {
                    <div class="hero-avatar-placeholder mx-auto">
                        <i class="bi bi-person"></i>
                    </div>
                }
            </div>
        </div>
    </div>

    <a href="#skills" class="scroll-indicator">
        <i class="bi bi-chevron-double-down fs-5"></i>
    </a>
</section>

<!-- ===== FEATURED SKILLS ===== -->
@if (Model.FeaturedSkills.Any())
{
    <section class="section-pad" id="skills">
        <div class="container">
            <div class="text-center mb-5">
                <p class="section-label">What I work with</p>
                <h2 class="section-title">Top <span>Skills</span></h2>
                <div class="section-divider"></div>
            </div>

            <div class="row g-3">
                @foreach (var skill in Model.FeaturedSkills)
                {
                    var levelLabel = skill.Level >= 85 ? "Expert"
                                   : skill.Level >= 70 ? "Advanced"
                                   : skill.Level >= 50 ? "Intermediate"
                                   : "Learning";
                    var badgeColor = skill.Level >= 85 ? "success"
                                   : skill.Level >= 70 ? "primary"
                                   : skill.Level >= 50 ? "warning"
                                   : "secondary";
                    <div class="col-sm-6 col-lg-4 animate-up">
                        <div class="skill-card">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="skill-name">@skill.Name</span>
                                <span class="skill-level-badge badge text-bg-@badgeColor">@levelLabel</span>
                            </div>
                            <div class="skill-track">
                                <div class="skill-fill" data-width="@skill.Level"></div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="text-center mt-4">
                <a asp-action="Resume" class="btn btn-outline-primary">
                    <i class="bi bi-bar-chart me-2"></i>See Full Skill Set
                </a>
            </div>
        </div>
    </section>
}

<!-- ===== FEATURED PROJECTS ===== -->
@if (Model.FeaturedProjects.Any())
{
    <section class="section-pad" style="background: var(--bs-secondary-bg)">
        <div class="container">
            <div class="text-center mb-5">
                <p class="section-label">My work</p>
                <h2 class="section-title">Featured <span>Projects</span></h2>
                <div class="section-divider"></div>
            </div>

            <div class="row g-4">
                @foreach (var project in Model.FeaturedProjects)
                {
                    <div class="col-md-6 col-lg-4 animate-up">
                        <div class="project-card">
                            <div class="project-img-placeholder">
                                <i class="bi bi-code-square"></i>
                            </div>
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-2">@project.Title</h5>
                                <p class="text-secondary small mb-3">
                                    @(project.Description.Length > 110 ? project.Description[..110] + "…" : project.Description)
                                </p>
                                <div class="mb-3">
                                    @foreach (var tag in project.TechStack.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).Take(4))
                                    {
                                        <span class="tech-badge">@tag</span>
                                    }
                                </div>
                                <div class="d-flex gap-2 flex-wrap">
                                    @if (!string.IsNullOrWhiteSpace(project.GitHubUrl))
                                    {
                                        <a href="@project.GitHubUrl" target="_blank" rel="noopener"
                                           class="project-link text-secondary">
                                            <i class="bi bi-github me-1"></i>Code
                                        </a>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(project.LiveUrl))
                                    {
                                        <a href="@project.LiveUrl" target="_blank" rel="noopener"
                                           class="project-link text-primary">
                                            <i class="bi bi-box-arrow-up-right me-1"></i>Live
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="text-center mt-5">
                <a asp-action="Projects" class="btn btn-primary btn-lg px-5">
                    <i class="bi bi-grid me-2"></i>View All Projects
                </a>
            </div>
        </div>
    </section>
}

<!-- ===== CTA STRIP ===== -->
<section class="section-pad-sm">
    <div class="container">
        <div class="rounded-4 p-5 text-center"
             style="background: linear-gradient(135deg, #1e3a5f, #0f172a)">
            <h3 class="fw-bold text-white mb-2">Let's work together</h3>
            <p class="text-secondary mb-4">Open to full-time roles and freelance opportunities.</p>
            <a asp-action="Contact" class="btn btn-primary btn-lg px-5">
                <i class="bi bi-chat-dots me-2"></i>Get in Touch
            </a>
        </div>
    </div>
</section>
