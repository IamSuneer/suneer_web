@{
    ViewData["Title"] = "Page Not Found";
}

<section class="section-pad d-flex align-items-center justify-content-center"
         style="min-height:60vh">
    <div class="text-center">
        <div class="display-1 fw-black mb-0" style="font-size:7rem;line-height:1;
             background:linear-gradient(135deg,#3b82f6,#8b5cf6);
             -webkit-background-clip:text;-webkit-text-fill-color:transparent;
             background-clip:text">404</div>

        <h2 class="fw-bold mt-3 mb-2">Page Not Found</h2>
        <p class="text-secondary mb-4" style="max-width:420px;margin:0 auto">
            The page you're looking for doesn't exist, was moved, or the URL is incorrect.
        </p>

        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">
                <i class="bi bi-house me-2"></i>Go Home
            </a>
            <button onclick="history.back()" class="btn btn-outline-secondary px-4">
                <i class="bi bi-arrow-left me-2"></i>Go Back
            </button>
        </div>
    </div>
</section>
