@model List<suneer_web.Models.Skill>
@{
    ViewData["Title"] = "Skills";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0">Skills</h4>
        <p class="text-muted small mb-0">@Model.Count skill(s) total</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Add Skill
    </a>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-stars fs-1 d-block mb-2 opacity-25"></i>
            No skills yet. <a asp-action="Create">Add your first skill.</a>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Skill</th>
                        <th style="width:220px">Proficiency</th>
                        <th style="width:80px" class="text-end">Level</th>
                        <th style="width:100px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var skill in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@skill.Name</td>
                            <td>
                                <div class="progress" style="height:8px">
                                    <div class="progress-bar @(skill.Level >= 80 ? "bg-success" : skill.Level >= 50 ? "bg-primary" : "bg-warning")"
                                         role="progressbar" style="width:@skill.Level%"
                                         aria-valuenow="@skill.Level" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            </td>
                            <td class="text-end text-muted small">@skill.Level%</td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="Edit" asp-route-id="@skill.Id"
                                       class="btn btn-sm btn-outline-secondary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" asp-action="Delete" asp-route-id="@skill.Id"
                                          onsubmit="return confirm('Delete skill \'@skill.Name\'?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
