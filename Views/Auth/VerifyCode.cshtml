@model suneer_web.Models.ViewModels.VerifyCodeViewModel
@{
    ViewData["Title"] = "Verify Reset Code";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify Code — Suneer Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #1e2a3a 0%, #0d1b2a 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .auth-card { width: 100%; max-width: 420px; border-radius: 1rem; }

        /* Big segmented code input feel */
        #Code {
            letter-spacing: .4em;
            font-size: 1.6rem;
            font-weight: 800;
            text-align: center;
            font-variant-numeric: tabular-nums;
        }
    </style>
</head>
<body>

<div class="auth-card card border-0 shadow-lg p-4">
    <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3
                    bg-info bg-opacity-10" style="width:64px;height:64px">
            <i class="bi bi-shield-check fs-3 text-info"></i>
        </div>
        <h4 class="fw-bold mb-0">Enter Reset Code</h4>
        <p class="text-muted small">
            A 6-digit code was sent to
            <strong class="text-body">@Model.Email</strong>
        </p>
    </div>

    @if (ViewBag.Info is string info)
    {
        <div class="alert alert-info py-2 small mb-3">
            <i class="bi bi-info-circle me-1"></i>@info
        </div>
    }

    <form asp-controller="PasswordReset" asp-action="VerifyCode" asp-area="" method="post">
        @Html.AntiForgeryToken()

        <!-- Hidden email — carried through the form -->
        <input type="hidden" asp-for="Email" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

        <div class="mb-4">
            <label asp-for="Code" class="form-label fw-semibold small text-center d-block"></label>
            <input asp-for="Code"
                   class="form-control"
                   id="Code"
                   maxlength="6"
                   inputmode="numeric"
                   pattern="\d{6}"
                   placeholder="000000"
                   autocomplete="one-time-code" />
            <span asp-validation-for="Code" class="text-danger small"></span>
            <div class="text-muted text-center small mt-2">
                <i class="bi bi-clock me-1"></i>Code expires in 15 minutes
            </div>
        </div>

        <button type="submit" class="btn btn-info w-100 py-2 fw-semibold text-white">
            <i class="bi bi-check2-circle me-2"></i>Verify Code
        </button>
    </form>

    <div class="text-center mt-3">
        <a asp-controller="PasswordReset" asp-action="ForgotPassword" asp-area=""
           class="text-decoration-none text-muted small">
            <i class="bi bi-arrow-repeat me-1"></i>Request a new code
        </a>
    </div>

    <p class="text-center text-muted small mt-2 mb-0">
        <a asp-controller="Auth" asp-action="Page" asp-area=""
           class="text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i>Back to Login
        </a>
    </p>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmJ5MbHZ/QHaXEpGp8apKAkGM0P"
        crossorigin="anonymous"></script>
<script>
    // Auto-submit when 6 digits entered
    document.getElementById('Code').addEventListener('input', function () {
        if (this.value.replace(/\D/g, '').length === 6) {
            this.form.submit();
        }
    });
</script>
<partial name="_ValidationScriptsPartial" />
</body>
</html>
